# PostgreSQL connection string (required)
# Example: postgres://user:password@localhost:5432/sykra
DATABASE_URL=

# Conductor service (required)
CONDUCTOR_BASE_URL=http://localhost:8200
CONDUCTOR_TOKEN=

# Encryption key for sensitive data (required, 64 hex chars)
ENCRYPTION_KEY=

# GitHub OAuth (required for GitHub sign-in)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Required in production; must exactly match GitHub OAuth callback URL
GITHUB_CALLBACK_URL=
# Optional; set to verify GitHub webhook signatures
GITHUB_WEBHOOK_SECRET=

# Email delivery bootstrap
EMAIL_PROVIDER=resend
EMAIL_FROM=
RESEND_API_KEY=
STUDIO_BASE_URL=http://localhost:8109
